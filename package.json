{
  "name": "mayhaim",
  "version": "2.4.3",
  "private": true,
  "description": "MayhAim — Aim trainer FPS + coaching hub",
  "author": "Maayyhem",
  "main": "electron-main.js",
  "scripts": {
    "setup-db": "node scripts/setup-db.js",
    "build:icons": "node scripts/build-icons.js",
    "electron": "electron .",
    "electron:dev": "electron . --dev",
    "dist": "npm run build:icons && electron-builder",
    "dist:win": "npm run build:icons && electron-builder --win",
    "dist:portable": "npm run build:icons && electron-builder --win portable"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@neondatabase/serverless": "^0.10.0",
    "bcryptjs": "^2.4.3",
    "electron-updater": "^6.8.3",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.mayhaim.aimtrainer",
    "productName": "MayhAim",
    "copyright": "Copyright © 2026 MayhAim",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "index.html",
      "profile.html",
      "coaching.js",
      "coachplayer.js",
      "game3d.js",
      "audio.js",
      "ui.js",
      "style.css",
      "three.min.js",
      "scenario-maps-data.js",
      "maps.js",
      "package.json",
      "CHANGELOG.md",
      "build/icon.ico",
      "build/icon.png",
      "build/icon.svg",
      "build/splash.html",
      "!build/icons/**",
      "!api/**",
      "!scripts/**",
      "!.env*",
      "!**/*.md",
      "!dist/**",
      "!vercel.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MayhAim",
      "uninstallDisplayName": "MayhAim — Aim Trainer",
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "Maayyhem",
      "repo": "mayhaim",
      "releaseType": "release"
    }
  }
}
